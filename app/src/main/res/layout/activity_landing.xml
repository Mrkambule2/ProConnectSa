<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Welcome to"
        android:textColor="#AAAAAA"
        android:textSize="20sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pro Connect SA"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Empowering Local Small Businesses"
        android:textColor="#00E5FF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Connecting South African communities with trusted local service providers. We empower small businesses by providing a digital platform to grow, while making everyday local services easily accessible to clients."
        android:textColor="#CCCCCC"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_landing_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#00E5FF"
        android:text="Login"
        android:textAllCaps="false"
        android:textColor="#121212"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="28dp" />

    <TextView
        android:id="@+id/btn_landing_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:text="New to Pro Connect? Sign Up"
        android:textColor="#00E5FF"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
